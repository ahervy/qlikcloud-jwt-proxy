PORT=3000
APP_BASE_URL=http://localhost:3000

# Qlik Cloud JWT identity provider configuration
TENANT_URI=your-tenant.region.qlikcloud.com
WEB_INTEGRATION_ID=your-web-integration-id
QLIK_JWT_ISSUER=your-qlik-jwt-issuer
QLIK_JWT_KEY_ID=your-qlik-jwt-key-id
QLIK_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Web application identity provider, for example Auth0
IDP_CLIENT_ID=your-idp-client-id
IDP_CLIENT_SECRET=your-idp-client-secret
IDP_URI=https://your-idp-domain.example.com
IDP_REDIRECT_URI=http://localhost:3000/login/callback
IDP_SCOPE=openid email profile

# Session storage. Use REDIS_URL or the host/port fields below.
# REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

SESSION_SECRET=replace-with-a-long-random-string
SESSION_MAX_AGE_MS=600000
COOKIE_SECURE=false

# Demo Qlik content shown by index.html
APP_ID=<APP_ID>
SHEET_ID=<SHEET_ID>
IFRAME_APP_ID=<APP_ID>
IFRAME_SHEET_ID=<SHEET_ID>
QLIK_THEME=breeze

# Qlik-embed object example configuration
QLIK_EMBED_APP_ID=<APP_ID>
QLIK_EMBED_OBJECT_ID=<OBJECT_ID>
