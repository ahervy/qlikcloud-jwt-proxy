PORT=3000
APP_BASE_URL=http://localhost:3000

# Qlik Cloud JWT identity provider configuration
tenantUri=your-tenant.region.qlikcloud.com
webIntegrationId=your-web-integration-id
issuer=your-qlik-jwt-issuer
keyId=your-qlik-jwt-key-id
privateKey="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Web application identity provider, for example Auth0
clientId=your-idp-client-id
clientSecret=your-idp-client-secret
idpUri=https://your-idp-domain.example.com
redirectUri=http://localhost:3000/login/callback
idpScope=openid email profile

# Session storage. Use REDIS_URL or the host/port fields below.
# REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
redis_port=6379
# redis_pwd=

sessionSecret=replace-with-a-long-random-string
SESSION_MAX_AGE_MS=600000
COOKIE_SECURE=false

# Demo Qlik content shown by index.html
APP_ID=<APP_ID>
SHEET_ID=<SHEET_ID>
IFRAME_APP_ID=<APP_ID>
IFRAME_SHEET_ID=<SHEET_ID>
QLIK_THEME=breeze

# The qlik-embed example is configured directly in index.html by editing the
# app-id and object-id attributes.
